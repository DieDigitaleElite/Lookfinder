# --- SERVER-SIDE SECRETS (Keep these hidden in Vercel/GitHub Settings) ---
# Required for Gemini AI API calls
GEMINI_API_KEY=
# Your Stripe Secret Key from dashboard.stripe.com (e.g., sk_test_...)
STRIPE_SECRET_KEY=

# --- SERVER-SIDE SECRETS (STRICTLY PRIVATE - Set in Vercel/GitHub Settings) ---
# DANGER: NEVER prefix these with VITE_
GEMINI_API_KEY=
STRIPE_SECRET_KEY=

# --- CLIENT-SIDE / FIREBASE CONFIG (Safe in JS Bundle, but set in Vercel) ---
# These identify your project. Security is handled via Firestore Rules.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
VITE_FIREBASE_DATABASE_ID=

# Google Analytics 4 Measurement ID
VITE_GA_MEASUREMENT_ID=

# Your Production URL
APP_URL=
