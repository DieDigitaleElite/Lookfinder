# --- SERVER-SIDE SECRETS (STRICTLY PRIVATE - Set in Vercel/GitHub Settings) ---
# DANGER: NEVER prefix these with VITE_ to keep them out of the JS bundle.
GEMINI_API_KEY=
STRIPE_SECRET_KEY=

# --- CLIENT-SIDE / FIREBASE CONFIG (Set in Vercel for bundle injection) ---
# Note: AI Studio injects GEMINI_API_KEY into the frontend safely. 
# For Vercel, you should use the proxy pattern if you want absolute secret protection.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_DATABASE_ID=

# Google Analytics 4 Measurement ID
VITE_GA_MEASUREMENT_ID=

# Your Production URL
APP_URL=
