# --- SERVER-SIDE SECRETS (Keep these hidden in Vercel/GitHub Settings) ---
# Required for Gemini AI API calls
GEMINI_API_KEY=
# Your Stripe Secret Key from dashboard.stripe.com (e.g., sk_test_...)
STRIPE_SECRET_KEY=

# --- FIREBASE SECRETS (SERVER-SIDE ONLY) ---
# We use these on the server to prevent leaking them into the JS bundle via VITE_ prefixes.
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=
FIREBASE_DATABASE_ID=

# Google Analytics 4 Measurement ID
VITE_GA_MEASUREMENT_ID=

# Your Production URL (e.g., https://your-app.vercel.app)
APP_URL=
