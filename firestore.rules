rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Helper Functions (The Primitives)
    // ===============================================================
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-\\.:, ]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'google@diedigitaleelite.de' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    // ===============================================================
    // Validation Blueprints (Anti-Update-Gap)
    // ===============================================================

    function isValidUser(data) {
      return data.uid == request.auth.uid;
    }

    function isValidResult(data, userId) {
      return data.userId == userId &&
             data.userId == request.auth.uid;
    }

    function isValidSketch(data, userId) {
      return true;
    }

    function isValidPoll(data) {
      return data.creatorId == request.auth.uid;
    }

    function isValidUsage(data) {
      return data.keys().hasAll(['count']) &&
             data.count is number;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // User Profile
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isOwner(userId) || isAdmin();
    }

    // Saved Hairstyle Results
    match /users/{userId}/results/{resultId} {
      allow list: if isOwner(userId) || isAdmin();
      allow get: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidResult(incoming(), userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isOwner(userId);
    }

    // Hairstyle Sketches (Styling Studio)
    match /users/{userId}/sketches/{sketchId} {
      allow list, get: if isOwner(userId) || isAdmin();
      allow create, update: if isOwner(userId) && isValidSketch(incoming(), userId);
      allow delete: if isOwner(userId);
    }

    // Public Voting Polls (Viral Loop)
    match /polls/{pollId} {
      allow get, list: if true;
      allow create: if isSignedIn() && isValidPoll(incoming());
      allow update: if true; 
      allow delete: if isOwner(existing().creatorId) || isAdmin();
    }

    // Usage Tracking (Enforce limits)
    match /usage/{usageId} {
      allow read, write: if true; // Publicly track usage for rate limiting
    }

    // Test Connection
    match /test/connection {
      allow get: if true;
    }
  }
}
