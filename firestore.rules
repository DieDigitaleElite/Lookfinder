rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Helper Functions (The Primitives)
    // ===============================================================
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-\\.:, ]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'google@diedigitaleelite.de' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    // ===============================================================
    // Validation Blueprints (Anti-Update-Gap)
    // ===============================================================

    function isValidUser(data) {
      return data.uid == request.auth.uid;
    }

    function isValidResult(data, userId) {
      return data.userId == userId &&
             data.userId == request.auth.uid;
    }

    function isValidSketch(data, userId) {
      return true;
    }

    function isValidPoll(data) {
      return data.creatorId == request.auth.uid;
    }

    function isValidUsage(data) {
      return data.keys().hasAll(['count']) &&
             data.count is number;
    }

    function isValidSupportTicket(data) {
      return data.keys().hasAll(['ticketId', 'userId', 'name', 'email', 'category', 'subject', 'message', 'status360', 'createdAt']) &&
             data.ticketId is string && data.ticketId.size() <= 128 &&
             data.userId is string && data.userId.size() <= 128 &&
             data.name is string && data.name.size() <= 128 &&
             data.email is string && data.email.size() <= 128 &&
             data.category is string && data.category.size() <= 64 &&
             data.subject is string && data.subject.size() <= 200 &&
             data.message is string && data.message.size() <= 10000 &&
             data.status360 is string && data.status360.size() <= 32 &&
             data.createdAt == request.time;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // User Profile
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isOwner(userId) || isAdmin();
    }

    // Saved Hairstyle Results
    match /users/{userId}/results/{resultId} {
      allow list: if isOwner(userId) || isAdmin();
      allow get: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidResult(incoming(), userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isOwner(userId);
    }

    // Hairstyle Sketches (Styling Studio)
    match /users/{userId}/sketches/{sketchId} {
      allow list, get: if isOwner(userId) || isAdmin();
      allow create, update: if isOwner(userId) && isValidSketch(incoming(), userId);
      allow delete: if isOwner(userId);
    }

    // Public Voting Polls (Viral Loop)
    match /polls/{pollId} {
      allow get: if true;
      allow list: if isSignedIn(); // Don't allow anonymous listing of all polls
      allow create: if isSignedIn() && isValidPoll(incoming());
      // Harden Update: Only allow voting (incrementing votes in options) OR Admin/Owner full edit
      allow update: if (isSignedIn() && (isOwner(existing().creatorId) || isAdmin())) || (
        // Public Voting Rule: Only allow changing the 'options' field
        incoming().diff(existing()).affectedKeys().hasOnly(['options']) &&
        // Basic check to ensure options size hasn't changed (prevents adding/removing options)
        incoming().options.size() == existing().options.size()
      );
      allow delete: if isOwner(existing().creatorId) || isAdmin();
    }

    // Usage Tracking (Enforce limits)
    match /usage/{usageId} {
      allow get: if true;
      allow create: if isValidId(usageId) && isValidUsage(incoming());
      allow update: if isValidId(usageId) && isValidUsage(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['count', 'lastUsed', 'isUser', 'updatedAt']);
    }

    // Support Tickets
    match /support_tickets/{ticketId} {
      allow list, get: if isAdmin();
      allow create: if isValidId(ticketId) && isValidSupportTicket(incoming());
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Test Connection
    match /test/connection {
      allow get: if true;
    }
  }
}
